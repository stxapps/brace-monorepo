{
  "name": "@stxapps/brace-web",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "tags": [
      "type:app",
      "platform:web"
    ],
    "targets": {
      "build": {
        "options": {
          "command": "next build && serwist build serwist.config.mjs"
        },
        "outputs": [
          "{projectRoot}/.next/!(cache)/**/*",
          "{projectRoot}/.next/!(cache)",
          "{projectRoot}/out"
        ]
      },
      "dev": {
        "options": {
          "command": "next dev --port 4000"
        }
      },
      "start": {
        "options": {
          "command": "next start --port 4000"
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@serwist/next": "^9.5.11",
    "@stxapps/shared": "*",
    "@stxapps/web-ui": "*",
    "@tanstack/react-query": "^5.101.0",
    "next": "~16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "serwist": "9.5.11"
  },
  "devDependencies": {
    "@serwist/cli": "^9.5.11",
    "@tailwindcss/postcss": "^4.3.0"
  }
}
