# Loaded automatically by `next build` (NODE_ENV=production) — the production deploy.
# All vars here are NEXT_PUBLIC_* and get baked into the static bundle, so nothing
# secret belongs in this file.
NEXT_PUBLIC_API_URL=https://api.brace.to
NEXT_PUBLIC_EXTRACT_URL=https://extract.brace.to

# Paddle Billing (src/lib/paddle.ts) — LIVE Paddle; client tokens are public by design.
NEXT_PUBLIC_PADDLE_ENV=production
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=TODO-live-client-token
