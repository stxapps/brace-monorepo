<?xml version="1.0" encoding="utf-8"?>
<!-- ShareActivity's window: fully transparent so the caller's app stays
     visible behind it — the JS side draws its own dimmed backdrop + bottom
     sheet (share-screen.tsx's Sheet). AppCompat parent is required:
     ReactActivity extends AppCompatActivity. -->
<resources>
  <style name="BraceShareTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
    <item name="android:windowIsTranslucent">true</item>
    <item name="android:windowBackground">@android:color/transparent</item>
    <item name="android:windowNoTitle">true</item>
    <item name="android:backgroundDimEnabled">false</item>
    <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
  </style>
</resources>
