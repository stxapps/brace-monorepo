# Loaded by Expo when NODE_ENV=production — i.e. a release build / `expo export`.
# EXPO_PUBLIC_* vars are inlined into the JS bundle at build time; nothing secret
# belongs here.
EXPO_PUBLIC_API_URL=https://api.brace.to
# The brace-web app's origin, for out-of-app pages the mobile app links to
# (Support).
EXPO_PUBLIC_WEB_URL=https://app.brace.to
