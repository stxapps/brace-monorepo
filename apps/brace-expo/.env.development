# Loaded by Expo when NODE_ENV=development — i.e. `expo start` / `nx dev`
# (the default dev server). Points at the local brace-api dev server
# (apps/brace-api, default PORT 8787). EXPO_PUBLIC_* vars are inlined into the
# JS bundle by Metro at build time, so nothing secret belongs here.
EXPO_PUBLIC_API_URL=http://localhost:8787
