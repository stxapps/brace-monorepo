# Loaded by `wxt build --mode staging` (mode=staging) — the testing deploy.
# Unlike brace-web's staging (which needs Nx `envFile`), wxt selects this file
# natively from `--mode staging`. WXT_PUBLIC_* vars are baked into the bundle, so
# nothing secret belongs here.
WXT_PUBLIC_API_URL=https://api.staging.brace.to
