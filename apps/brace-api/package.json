{
  "name": "@stxapps/brace-api",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "tags": [
      "type:app",
      "platform:worker"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "outputs": [
          "{projectRoot}/dist"
        ],
        "options": {
          "command": "wrangler deploy --env staging --dry-run --outdir dist",
          "cwd": "apps/brace-api"
        }
      },
      "deploy": {
        "executor": "nx:run-commands",
        "options": {
          "command": "wrangler deploy --env staging",
          "cwd": "apps/brace-api"
        },
        "configurations": {
          "production": {
            "command": "wrangler deploy --env production"
          }
        }
      },
      "migrate": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "wrangler d1 migrations apply DIRECTORY_DB --env development",
            "wrangler d1 migrations apply ACCOUNTS_DB_1 --env development",
            "wrangler d1 migrations apply SESSIONS_DB --env development"
          ],
          "parallel": false,
          "cwd": "apps/brace-api"
        },
        "configurations": {
          "staging": {
            "commands": [
              "wrangler d1 migrations apply DIRECTORY_DB --env staging",
              "wrangler d1 migrations apply ACCOUNTS_DB_1 --env staging",
              "wrangler d1 migrations apply SESSIONS_DB --env staging"
            ]
          },
          "production": {
            "commands": [
              "wrangler d1 migrations apply DIRECTORY_DB --env production",
              "wrangler d1 migrations apply ACCOUNTS_DB_1 --env production",
              "wrangler d1 migrations apply SESSIONS_DB --env production"
            ]
          }
        }
      }
    }
  },
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --env development"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "hono": "^4.12.23",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260605.1",
    "wrangler": "^4.98.0"
  }
}
