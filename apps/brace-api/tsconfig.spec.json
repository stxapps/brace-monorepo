{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/jest",
    "types": ["@cloudflare/workers-types", "jest", "node"],
    "module": "commonjs",
    "moduleResolution": "node10",
    "verbatimModuleSyntax": false
  },
  "include": ["jest.config.ts", "src/**/*.test.ts", "src/**/*.spec.ts", "src/**/*.d.ts"],
  "references": [
    {
      "path": "./tsconfig.json"
    }
  ]
}
