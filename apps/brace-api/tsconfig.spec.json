{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "outDir": "./out-tsc/vitest",
    "types": ["@cloudflare/workers-types", "node"]
  },
  // Compile the app sources DIRECTLY (src/**/*.ts covers app code + specs) rather
  // than pulling app types via a project reference to the composite tsconfig.app.json.
  // A `tsc -p` reference resolves the composite project's types from its emitted
  // dist/*.d.ts, which the --noEmit typecheck never writes — so a reference makes
  // `npx nx typecheck @stxapps/brace-api` fail (TS6305) on a clean/changed tree.
  // Compiling from source keeps this pass self-contained, with no prior build. The
  // strict app-only pass (tsconfig.app.json, no "node" types) stays the portability
  // gate; this pass adds the specs + node / cloudflare:test types.
  "include": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
}
