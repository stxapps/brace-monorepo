# Nx task running — committed, non-secret workspace defaults.
# (Auto-loaded by nx run-many/run-one/affected via loadRootEnvFiles; secrets
# belong in .env.local / .env*.local, which are gitignored.)

# Disable Nx's native pseudo-terminal so tasks inherit the real terminal width.
# The PTY is sized independently of your terminal, which makes tools that format
# to the detected TTY width (jest, next, wrangler + their spinners) wrap at the
# wrong column and emit stray newlines. Plain child processes wrap correctly.
NX_NATIVE_COMMAND_RUNNER=false

# Restore color output lost when the PTY goes away (tools no longer detect a TTY).
FORCE_COLOR=1
